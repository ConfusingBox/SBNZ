package com.ftn.sbnz.rules;

import com.ftn.sbnz.model.Klijent;
import com.ftn.sbnz.model.KreditniDogadjaj;
import com.ftn.sbnz.model.KreditnaIstorija;
import com.ftn.sbnz.model.NegativniBod;
import java.time.LocalDateTime;

// Deklarisemo rolu event-a nad postojecim klasama
declare NegativniBod
    @role(event)
end

declare KreditniDogadjaj
    @role(event)
    @timestamp( datum.atZone(java.time.ZoneId.systemDefault()).toInstant().toEpochMilli() )
end

// Pomocni model deklarisan direktno u DRL-u koji pamti tacno koji je objekat dogadjaja obradjen
declare ObradjenDogadjaj
    dogadjaj: KreditniDogadjaj
end

// --- CEP BODOVANJE (CIST STRIM) ---

rule "CEP - Kasnjenje do 30 dana"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "KASNJENJE_DO_30")
    // Osigurava da se ovaj konkretni dogadjaj obradi samo jednom, bez obzira na kolicinu drugih dogadjaja u istoj sekundi
    not ObradjenDogadjaj(dogadjaj == $d)
then
    insert(new ObradjenDogadjaj($d));
    insert(new NegativniBod($k, 1));
end

rule "CEP - Kasnjenje 30-90 dana"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "KASNJENJE_30_90")
    not ObradjenDogadjaj(dogadjaj == $d)
then
    insert(new ObradjenDogadjaj($d));
    insert(new NegativniBod($k, 3));
end

rule "CEP - Kasnjenje preko 90 dana"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "KASNJENJE_PREKO_90")
    not ObradjenDogadjaj(dogadjaj == $d)
then
    insert(new ObradjenDogadjaj($d));
    insert(new NegativniBod($k, 5));
end

rule "CEP - Prinudna naplata"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "PRINUDNA_NAPLATA")
    not ObradjenDogadjaj(dogadjaj == $d)
then
    insert(new ObradjenDogadjaj($d));
    insert(new NegativniBod($k, 8));
end

rule "CEP - Stecaj ili reprogram"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "STECAJ")
    not ObradjenDogadjaj(dogadjaj == $d)
then
    insert(new ObradjenDogadjaj($d));
    insert(new NegativniBod($k, 10));
end

rule "CEP - Odbijen kredit"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "ODBIJEN_KREDIT")
    not ObradjenDogadjaj(dogadjaj == $d)
then
    insert(new ObradjenDogadjaj($d));
    insert(new NegativniBod($k, 2));
end

rule "CEP - Uredno izmirenje (Pozitivan factor)"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "UREDNO_IZMIRIVANJE")
    not ObradjenDogadjaj(dogadjaj == $d)
then
    insert(new ObradjenDogadjaj($d));
    insert(new NegativniBod($k, -3));
end

// --- AKUMULACIJA BODOVA ---

rule "Suma negativnih bodova"
    dialect "java"
    salience 10
when
    $k: Klijent()
    $suma: Number() from accumulate(
        NegativniBod(klijent == $k, $b: bodovi),
        sum($b)
    )
then
    modify($k) {
        setUkupnoNegativnihBodova($suma.intValue())
    }
    System.out.println(">> CEP Rezultat: Klijent " + $k.getIme() + " ima ukupno " + $suma.intValue() + " negativnih bodova.");
end

// --- KLASIFIKACIJA ISTORIJE ---

rule "Odredjivanje istorije: Odlicna (0-2 boda)"
    dialect "java"
    salience -100 
when
    $k: Klijent(ukupnoNegativnihBodova >= 0, ukupnoNegativnihBodova <= 2, kreditnaIstorija == null || kreditnaIstorija.name() != "ODLICNA")
then
    System.out.println(">> CEP Klasifikacija: Istorija klijenta azurirana na ODLICNA.");
    modify($k) {
        setKreditnaIstorija(KreditnaIstorija.ODLICNA)
    }
end

rule "Odredjivanje istorije: Dobra (3-5 bodova)"
    dialect "java"
    salience -100
when
    $k: Klijent(ukupnoNegativnihBodova >= 3, ukupnoNegativnihBodova <= 5, kreditnaIstorija == null || kreditnaIstorija.name() != "DOBRA")
then
    System.out.println(">> CEP Klasifikacija: Istorija klijenta azurirana na DOBRA.");
    modify($k) {
        setKreditnaIstorija(KreditnaIstorija.DOBRA)
    }
end

rule "Odredjivanje istorije: Losa (6-9 bodova)"
    dialect "java"
    salience -100
when
    $k: Klijent(ukupnoNegativnihBodova >= 6, ukupnoNegativnihBodova <= 9, kreditnaIstorija == null || kreditnaIstorija.name() != "LOSA")
then
    System.out.println(">> CEP Klasifikacija: Istorija klijenta azurirana na LOSA.");
    modify($k) {
        setKreditnaIstorija(KreditnaIstorija.LOSA)
    }
end

rule "Odredjivanje istorije: Neprihvatljiva (10+ bodova)"
    dialect "java"
    salience -100
when
    $k: Klijent(ukupnoNegativnihBodova >= 10, kreditnaIstorija == null || kreditnaIstorija.name() != "NEPRIHVATLJIVA")
then
    System.out.println(">> CEP Klasifikacija: Istorija klijenta azurirana na NEPRIHVATLJIVA.");
    modify($k) {
        setKreditnaIstorija(KreditnaIstorija.NEPRIHVATLJIVA)
    }
end