package com.ftn.sbnz.rules;

import com.ftn.sbnz.model.Klijent;
import com.ftn.sbnz.model.KreditniDogadjaj;
import com.ftn.sbnz.model.KreditnaIstorija;
import java.time.LocalDate;

//Pomocna klasa u Droolsu za cuvanje bodova
declare NegativniBod
    klijent: Klijent
    bodovi: int
end

//CEP bodovanje

rule "CEP - Kašnjenje do 30 dana"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "KASNJENJE_DO_30") from $k.getIstorija()
then
    insert(new NegativniBod($k, 1));
end

rule "CEP - Kašnjenje 30-90 dana"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "KASNJENJE_30_90") from $k.getIstorija()
then
    insert(new NegativniBod($k, 2));
end

rule "CEP - Kašnjenje preko 90 dana"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "KASNJENJE_PREKO_90") from $k.getIstorija()
then
    insert(new NegativniBod($k, 4));
end

rule "CEP - Prinudna naplata u poslednjih 12 meseci"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "PRINUDNA_NAPLATA", datum.isAfter(LocalDate.now().minusMonths(12))) from $k.getIstorija()
then
    insert(new NegativniBod($k, 10));
end

rule "CEP - Prinudna naplata pre više od 12 meseci"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "PRINUDNA_NAPLATA", datum.isBefore(LocalDate.now().minusMonths(12))) from $k.getIstorija()
then
    insert(new NegativniBod($k, 5));
end

rule "CEP - Stečaj/Reprogram u poslednjih 12 meseci"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "STECAJ", datum.isAfter(LocalDate.now().minusMonths(12))) from $k.getIstorija()
then
    insert(new NegativniBod($k, 10));
end

rule "CEP - Stečaj/Reprogram pre više od 12 meseci"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "STECAJ", datum.isBefore(LocalDate.now().minusMonths(12))) from $k.getIstorija()
then
    insert(new NegativniBod($k, 7));
end

rule "CEP - Odbijen kredit u poslednjih 6 meseci"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "ODBIJEN_KREDIT", datum.isAfter(LocalDate.now().minusMonths(6))) from $k.getIstorija()
then
    insert(new NegativniBod($k, 2));
end

rule "CEP - Odbijen kredit pre više od 6 meseci"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "ODBIJEN_KREDIT", datum.isBefore(LocalDate.now().minusMonths(6))) from $k.getIstorija()
then
    insert(new NegativniBod($k, 1));
end

rule "CEP - Uredno izmirivanje duže od 3 godine"
when
    $k: Klijent()
    $d: KreditniDogadjaj(tipDogadjaja == "UREDNO_IZMIRIVANJE", datum.isBefore(LocalDate.now().minusYears(3))) from $k.getIstorija()
then
    insert(new NegativniBod($k, -2)); 
end


//Accumulate, sabiram bodove

rule "Akumulacija negativnih bodova"
    dialect "java"
    salience -50 //izvrsava se pre same istorije
when
    $k: Klijent()
    $suma: Number() from accumulate(
        NegativniBod(klijent == $k, $b : bodovi),
        sum($b)
    )
then
    int izracunato = $suma.intValue();
    if (izracunato < 0) {
        izracunato = 0;
    }
    
    System.out.println(">> CEP Rezultat: Klijent " + $k.getIme() + " ima ukupno " + izracunato + " negativnih bodova.");
    
    modify($k) {
        setUkupnoNegativnihBodova(izracunato)
    }
end


//Odredjivanje istorije na osnovu skale

rule "Određivanje istorije: Odlična (0-2 boda)"
    dialect "java"
    salience -100 //cekam akumulaciju da se zavrsi
when
    $k: Klijent(ukupnoNegativnihBodova >= 0, ukupnoNegativnihBodova <= 2, kreditnaIstorija != KreditnaIstorija.ODLICNA)
then
    System.out.println(">> CEP Klasifikacija: Istorija klijenta azurirana na ODLICNA.");
    modify($k) {
        setKreditnaIstorija(KreditnaIstorija.ODLICNA)
    }
end

rule "Određivanje istorije: Dobra (3-5 bodova)"
    dialect "java"
    salience -100
when
    $k: Klijent(ukupnoNegativnihBodova >= 3, ukupnoNegativnihBodova <= 5, kreditnaIstorija != KreditnaIstorija.DOBRA)
then
    System.out.println(">> CEP Klasifikacija: Istorija klijenta azurirana na DOBRA.");
    modify($k) {
        setKreditnaIstorija(KreditnaIstorija.DOBRA)
    }
end

rule "Određivanje istorije: Loša (6-9 bodova)"
    dialect "java"
    salience -100
when
    $k: Klijent(ukupnoNegativnihBodova >= 6, ukupnoNegativnihBodova <= 9, kreditnaIstorija != KreditnaIstorija.LOSA)
then
    System.out.println(">> CEP Klasifikacija: Istorija klijenta azurirana na LOSA.");
    modify($k) {
        setKreditnaIstorija(KreditnaIstorija.LOSA)
    }
end

rule "Određivanje istorije: Neprihvatljiva (10+ bodova)"
    dialect "java"
    salience -100
when
    $k: Klijent(ukupnoNegativnihBodova >= 10, kreditnaIstorija != KreditnaIstorija.NEPRIHVATLJIVA)
then
    System.out.println(">> CEP Klasifikacija: Istorija klijenta azurirana na NEPRIHVATLJIVA.");
    modify($k) {
        setKreditnaIstorija(KreditnaIstorija.NEPRIHVATLJIVA)
    }
end