package com.ftn.sbnz.rules.klasifikacija;

import com.ftn.sbnz.model.KreditniZahtev;
import com.ftn.sbnz.model.Klijent;
import com.ftn.sbnz.model.Status;
import com.ftn.sbnz.model.KreditniRazred;
import com.ftn.sbnz.model.KreditnaIstorija;

//prvi prioritet, najopasniji uslovi
rule "Klasifikacija - Razred E (Stecaj)"
salience 100
when
    $z: KreditniZahtev(status == Status.IZRACUNAT_DTI)
    $k: Klijent(imaStecajIliNaplatuU12Meseci() == true) from $z.getKlijent()
then
    System.out.println("Pravilo: Klasifikacija E - Detektovan stecaj/naplata.");
    $z.setRazred(KreditniRazred.E);
    $z.setStatus(Status.ODBIJEN);
    $z.setObrazlozenje("Odbijeno: Stecaj ili prinudna naplata u poslednjih 12 meseci.");
    update($z);
end

//2 razred A
rule "Klasifikacija - Razred A"
when
    $z: KreditniZahtev(status == Status.IZRACUNAT_DTI, dti < 0.3)
    $k: Klijent(kreditnaIstorija == KreditnaIstorija.ODLICNA, slobodanPrihod >= 0.3) from $z.getKlijent()
then
    System.out.println("Pravilo: Klasifikacija A.");
    $z.setRazred(KreditniRazred.A);
    $z.setStatus(Status.ODOBREN);
    $z.setObrazlozenje("Odobreno: Odlicna istorija i prihvatljiv DTI.");
    update($z);
end

//3 razred B
rule "Klasifikacija - Razred B"
when
    $z: KreditniZahtev(status == Status.IZRACUNAT_DTI, dti < 0.4)
    $k: Klijent(kreditnaIstorija == KreditnaIstorija.DOBRA, slobodanPrihod >= 0.25) from $z.getKlijent()
then
    System.out.println("Pravilo: Klasifikacija B.");
    $z.setRazred(KreditniRazred.B);
    $z.setStatus(Status.ODOBREN);
    $z.setObrazlozenje("Odobreno: Dobra istorija i prihvatljiv DTI.");
    update($z);
end

//4 razred C
rule "Klasifikacija - Razred C"
when
    $z: KreditniZahtev(status == Status.IZRACUNAT_DTI, dti < 0.5)
    $k: Klijent(kreditnaIstorija == KreditnaIstorija.LOSA) from $z.getKlijent()
then
    System.out.println("Pravilo: Klasifikacija C.");
    $z.setRazred(KreditniRazred.C);
    $z.setStatus(Status.ZAVRSENO); 
    $z.setObrazlozenje("Uslovno odobreno: Potrebni dodatni kolaterali.");
    update($z);
end

//5 r azred D (bindovan $k za sigurnost)
rule "Klasifikacija - Razred D"
when
    $z: KreditniZahtev(status == Status.IZRACUNAT_DTI)
    $k: Klijent(kreditnaIstorija == KreditnaIstorija.NEPRIHVATLJIVA) from $z.getKlijent()
    eval($z.getDti() >= 0.5 || !$z.isKolateralPostoji()) //spajam ova dva uslova
then
    System.out.println("Pravilo: Klasifikacija D.");
    $z.setRazred(KreditniRazred.D);
    $z.setStatus(Status.ODBIJEN);
    $z.setObrazlozenje("Odbijeno: Visok DTI ili losa istorija bez kolaterala.");
    update($z);
end

rule "DEBUG - Zasto se ne klasifikuje"
salience -100 // Ovo pravilo se izvrsava poslednje
when
    $z: KreditniZahtev(status == Status.IZRACUNAT_DTI)
    $k: Klijent() from $z.getKlijent()
then
    System.out.println("DEBUG: Pravila za klasifikaciju nisu prosla.");
    System.out.println("DEBUG: DTI je: " + $z.getDti());
    System.out.println("DEBUG: Istorija je: " + $k.getKreditnaIstorija());
    System.out.println("DEBUG: Slobodan prihod je: " + $k.getSlobodanPrihod());
end